rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This is necessary for displaying user-uploaded content like profile pictures.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Secure the profileImages folder.
    match /profileImages/{userId}/{allPaths=**} {
      // Allow a user to write (create, update, delete) to their own folder.
      // This ensures that a user can only upload their own profile picture.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
