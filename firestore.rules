
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
     * Helper Functions
     * ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }
    
    function isManager() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid));
    }
    
    function isExistingDoc() {
      return resource != null;
    }
    
    function isNewDoc() {
      return resource == null;
    }
    
    function requestData() {
      return request.resource.data;
    }
    
    function isCreatingOwnUserDoc(userId) {
      // Very permissive rule for debugging. 
      // In production, you'd want to validate fields.
      return isOwner(userId);
    }
    
    // A user can update their own profile, but cannot change protected fields.
    function isUpdatingOwnUserDoc(userId) {
        let protectedFields = ['id', 'createdAt', 'tier', 'verified', 'referralPoints', 'cashPaymentStatus', 'referredByCode', 'email'];
        let incomingData = request.resource.data;
        let changedKeys = incomingData.diff(resource.data).affectedKeys();

        // 1. User must be the owner
        if (!isOwner(userId)) {
            return false;
        }

        // 2. The document must exist
        if (!isExistingDoc()) {
            return false;
        }
        
        // 3. If only 'following' or 'groups' are being changed, allow it.
        if (changedKeys.hasOnly(['following']) || changedKeys.hasOnly(['groups'])) {
            return true;
        }
        
        // 4. For any other changes, ensure no protected fields are being modified.
        if (changedKeys.hasAny(protectedFields)) {
            return false;
        }
        
        // 5. If role is being changed, ensure it's not to an admin role
        if ('role' in incomingData && incomingData.role != resource.data.role) {
            let allowedRoles = ["Freelancer", "Company", "Authorized Pro"];
             if (!(incomingData.role in allowedRoles)) {
                return false;
            }
        }
        
        // 6. If all checks pass, allow the update.
        return true;
    }

    // A manager can only update verification and cash payment status.
    function isManagerUpdatingUserDoc() {
      let editableFields = ['verified', 'cashPaymentStatus'];
      let allAffectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return isManager() && isExistingDoc() && allAffectedKeys.hasOnly(editableFields);
    }
    
    // A super admin can update any field except id and createdAt
    function isSuperAdminUpdatingUserDoc() {
        return isSuperAdmin() && isExistingDoc() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'createdAt']);
    }

    function isCreatingOwnLocationData(userId) {
      return isCreatingOwnUserDoc(userId) && requestData().userId == userId;
    }

    function locationUserImmutable() {
      return requestData().userId == resource.data.userId;
    }

    function isMemberOfCompany(companyId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc.data.companyId == companyId;
    }
    
    function isCompanyUser() {
        return isSignedIn() && request.auth.uid != null;
    }

    function isPremiumCompanyUser() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() &&
             userDoc.data.role == 'Company' &&
             (userDoc.data.tier == 'Premier' || userDoc.data.tier == 'Super Premier');
    }

    function isVacancyOwner(vacancy) {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return isCompanyUser() && 'companyId' in userDoc.data && vacancy.companyId == userDoc.data.companyId;
    }
    
    function isCreatingCorrectVacancy() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        // The companyId in the new vacancy must match the companyId of the user creating it.
        // Also ensure the user document has a companyId to compare against.
        return 'companyId' in userDoc.data && requestData().companyId == userDoc.data.companyId;
    }

    function isPremiumExpert() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return isSignedIn() && 
               (userDoc.data.tier == 'Premier' || userDoc.data.tier == 'Super Premier');
    }

    function isTargetExpertPremium(expertId) {
      let expertDoc = get(/databases/$(database)/documents/users/$(expertId));
      return expertDoc.data.tier == 'Premier' || expertDoc.data.tier == 'Super Premier';
    }

    function isPostAuthor(postId) {
        let post = get(/databases/$(database)/documents/posts/$(postId));
        return isSignedIn() && post.data.authorId == request.auth.uid;
    }
    
    function isApplicationOwner(userId) {
        return request.auth.uid == userId;
    }
    
    function isVacancyOwnerForApplication() {
        let vacancy = get(/databases/$(database)/documents/vacancies/$(requestData().vacancyId));
        return isVacancyOwner(vacancy.data);
    }


    /* =====================================================
     * Admin Roles
     * ===================================================== */

    match /roles_super_admin/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list, create, update, delete: if isSuperAdmin();
    }
    
    match /roles_manager/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin() || isManager();
      allow list, create, update, delete: if isSuperAdmin();
    }


    /* =====================================================
     * App Configuration
     * ===================================================== */
    match /app_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    /* =====================================================
     * Companies
     * ===================================================== */

    match /companies/{companyId} {
      allow get: if isSignedIn(); // Any signed-in user can view company details.
      allow list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }
    
    /* =====================================================
     * Payments
     * ===================================================== */
    match /payments/{paymentId} {
        // Users can create their own payment record, but can't specify status or update it later.
        allow create: if isOwner(requestData().userId) && requestData().status == 'pending';
        // Users can read their own payment records. Admins can read any.
        allow get: if isOwner(resource.data.userId) || isSuperAdmin();
        // Admins can list all payments. Users can list their own.
        allow list: if isSuperAdmin() || (isSignedIn() && request.query.where.userId == request.auth.uid);
        // Only super admins can update payment status.
        allow update, delete: if isSuperAdmin();
    }


    /* =====================================================
     * Users
     * ===================================================== */
    match /users/{userId} {
      // Anyone can view any public profile.
      allow get: if true;
      allow list: if true;

      // VERY PERMISSIVE: Any signed-in user can create their own user document.
      allow create: if isOwner(userId);
      
      /* ---------------------------------------------
       * Private Notifications (STRICT PRIVACY)
       * --------------------------------------------- */
       match /notifications/{notificationId} {
         // A user can read their own notifications.
         allow get, list: if isOwner(userId);
         // A signed-in user can create a notification, but only if they are the "actor".
         allow create: if isSignedIn() && request.auth.uid == requestData().actorId;
         // Only the owner can update (e.g., mark as read) or delete their notifications.
         allow update, delete: if isOwner(userId);
       }
       
      /* ---------------------------------------------
       * Private Location Data (STRICT PRIVACY)
       * --------------------------------------------- */

      match /location_data/{locationDataId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnLocationData(userId);
        allow update: if isOwner(userId) && locationUserImmutable();
        allow delete: if isOwner(userId);
      }

      // A user can update their own document, or a super admin can update any document.
      // This MUST come AFTER subcollection matches.
      allow update: if isSuperAdminUpdatingUserDoc() || isUpdatingOwnUserDoc(userId);

      // Users can delete their own account, and admins can delete any account.
      allow delete: if isOwner(userId) || isSuperAdmin();
    }
    
    /* =====================================================
     * Posts
     * ===================================================== */
    match /posts/{postId} {
        allow list: if true;
        allow get: if true;

        // Users can create their own posts
        allow create: if isSignedIn() && requestData().authorId == request.auth.uid;
        
        // Let's refine the update rule
        allow update: if isSuperAdmin() || // Super admins can do anything
                       // Any signed in user can update ONLY the likes array
                       (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])) ||
                       // The author can update the content and imageUrl, but not likes or other fields
                       (isPostAuthor(postId) && request.resource.data.diff(resource.data).hasAny(['content', 'imageUrl', 'title', 'link']));

        
        // Users can delete their own posts, or a super admin can.
        allow delete: if isPostAuthor(postId) || isSuperAdmin();

        /* ---------------------------------------------
        * Comments Subcollection
        * --------------------------------------------- */
        match /comments/{commentId} {
            // Anyone can read comments
            allow read: if true;
            // Any signed-in user can create a comment
            allow create: if isSignedIn() && requestData().authorId == request.auth.uid;
            
            // Refined update rule for comments
            allow update: if isSuperAdmin() || // Super admins can do anything
                           // Any signed-in user can update ONLY the likes array
                           (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])) ||
                           // The author can update ONLY the content
                           (isSignedIn() && resource.data.authorId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content']));

            // The author of the comment, the author of the post, or a super admin can delete.
            allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isPostAuthor(postId) || isSuperAdmin());
        }
    }
    
    /* =====================================================
     * Groups
     * ===================================================== */
    match /groups/{groupId} {
        function isGroupCreator() {
            return isSignedIn() && resource.data.creatorId == request.auth.uid;
        }

        // Use a get() call to check membership for sub-collection reads
        function isGroupMember() {
            if (!isSignedIn()) {
                return false;
            }
            let groupDoc = get(/databases/$(database)/documents/groups/$(groupId));
            return request.auth.uid in groupDoc.data.members;
        }
        
        function isRequestingToJoin() {
            // Check that the ONLY change is adding the current user's ID to the pendingMembers array.
            return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingMembers']) &&
                   request.resource.data.pendingMembers.size() == resource.data.pendingMembers.size() + 1 &&
                   request.auth.uid in request.resource.data.pendingMembers;
        }
        
        function isChangingOwnMembership() {
          let changes = request.resource.data.diff(resource.data);
          // Allow changing ONLY the members array
          if (!changes.affectedKeys().hasOnly(['members'])) {
            return false;
          }
          // Allow only adding or removing SELF from the members array
          let added = changes.addedKeys().filter(key => key.size() == 2 && key[0] == 'members' && key[1] == request.auth.uid).size() == 1;
          let removed = changes.removedKeys().filter(key => key.size() == 2 && key[0] == 'members' && key[1] == request.auth.uid).size() == 1;
          return (added && !removed) || (!added && removed);
        }

        function isCreatorManagingRequests() {
            return isGroupCreator() && 
                   (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'pendingMembers']) || 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingMembers']));
        }
        
        // Allow anyone to view a single group's details and list all groups
        allow get: if true;
        allow list: if true;
        
        allow create: if isSignedIn() && requestData().creatorId == request.auth.uid && request.auth.uid in requestData().members;
        
        allow update: if isSuperAdmin() || 
                       (isGroupCreator() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members', 'pendingMembers'])) || // Creator can edit details
                       (isSignedIn() && resource.data.privacy == 'public' && isChangingOwnMembership()) || // Public group join/leave
                       (isSignedIn() && resource.data.privacy == 'private' && isRequestingToJoin()) || // Private group request to join
                       isCreatorManagingRequests(); // Creator manages private group requests
                       
        allow delete: if isSuperAdmin() || isGroupCreator();

        match /posts/{postId} {
            // Only group members can read or list posts within the group
            allow read, list: if isGroupMember(); 
            allow create: if isGroupMember() && request.resource.data.authorId == request.auth.uid;
            allow update: if isSuperAdmin() ||
                           (isGroupMember() && resource.data.authorId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasAny(['content', 'title', 'link']));
            allow delete: if (isGroupMember() && resource.data.authorId == request.auth.uid) || isSuperAdmin();
        }
    }
    
    /* =====================================================
     * Vacancies
     * ===================================================== */
    match /vacancies/{vacancyId} {
        // Anyone can read and list job vacancies.
        allow get, list: if true;
        // Only premium company users or super admins can create vacancies.
        allow create: if (isPremiumCompanyUser() && isCreatingCorrectVacancy()) || isSuperAdmin();
        // Only the company that owns the vacancy (and is premium) or a super admin can update it.
        allow update: if (isPremiumCompanyUser() && isVacancyOwner(requestData())) || isSuperAdmin();
        // Only the company that owns the vacancy (and is premium) or a super admin can delete it.
        allow delete: if (isPremiumCompanyUser() && isVacancyOwner(resource.data)) || isSuperAdmin();
    }
    
    /* =====================================================
     * Applications
     * ===================================================== */
    match /applications/{applicationId} {
      // Allow a user to create their own application document
      allow create: if isApplicationOwner(requestData().userId);

      // Allow a user to read their own application, a super admin, or the vacancy owner
      allow get: if isApplicationOwner(resource.data.userId) || isSuperAdmin() || isVacancyOwnerForApplication();

      // Only allow listing by super admins or based on specific queries
      allow list: if isSuperAdmin() || 
                    (request.query.where.size() > 0 && 
                      ((request.query.where.userId == request.auth.uid) || 
                       (request.query.where.vacancyId != null && isVacancyOwner(get(/databases/$(database)/documents/vacancies/$(request.query.where.vacancyId)).data)))
                    );


      allow update: if false; // No updates allowed after creation
      allow delete: if isSuperAdmin() || isApplicationOwner(resource.data.userId);
    }


    /* =====================================================
     * Default Deny (implicit)
     * ===================================================== */
  }
}
    
    


    


    