
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
     * Helper Functions
     * ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }

    function isExistingDoc() {
      return resource != null;
    }

    function isCreatingOwnUserDoc(userId) {
      return isOwner(userId) &&
        request.resource.data.id == userId;
    }

    function userIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    function isCreatingOwnLocationData(userId) {
      return request.resource.data.userId == userId;
    }

    function locationUserImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    function isMemberOfCompany(companyId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.companyId == companyId;
    }
    
    function isCompanyUser() {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Company';
    }

    function isPremiumCompanyUser() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() &&
             user.role == 'Company' &&
             (user.tier == 'Premier' || user.tier == 'Super Premier');
    }

    function isVacancyOwner(vacancy) {
        return isCompanyUser() && vacancy.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }


    /* =====================================================
     * Super Admin Roles
     * ===================================================== */

    match /roles_super_admin/{userId} {
      allow get: if isOwner(userId);
      allow list, create, update, delete: if isSuperAdmin();
    }

    /* =====================================================
     * App Configuration
     * ===================================================== */
    match /app_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    /* =====================================================
     * Companies
     * ===================================================== */

    match /companies/{companyId} {
      allow get: if isSuperAdmin() || isMemberOfCompany(companyId);
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin() && isExistingDoc();
    }

    /* =====================================================
     * Users
     * ===================================================== */

    match /users/{userId} {
      // Public profiles (search, listings)
      allow get: if true;
      allow list: if true;

      // User onboarding
      allow create: if isCreatingOwnUserDoc(userId);

      // Secure updates
      allow update: if
        (isOwner(userId) && userIdImmutable()) ||
        isSuperAdmin();

      allow delete: if
        (isOwner(userId) || isSuperAdmin()) &&
        isExistingDoc();

      /* ---------------------------------------------
       * Private Location Data (STRICT PRIVACY)
       * --------------------------------------------- */

      match /location_data/{locationDataId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isCreatingOwnLocationData(userId);
        allow update: if isOwner(userId) && locationUserImmutable();
        allow delete: if isOwner(userId);
      }
    }
    
    /* =====================================================
     * Reviews
     * ===================================================== */
    match /reviews/{reviewId} {
        allow get, list: if isSuperAdmin();
        allow create: if (isSuperAdmin()) || (isSignedIn() && request.resource.data.status == 'pending');
        allow update: if isSuperAdmin()
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
            && request.resource.data.status in ['approved', 'rejected'];
        allow delete: if isSuperAdmin();
    }
    
    /* =====================================================
     * Vacancies
     * ===================================================== */
    match /vacancies/{vacancyId} {
        allow get: if true;
        allow list: if true;
        allow create: if isPremiumCompanyUser() || isSuperAdmin();
        allow update: if (isPremiumCompanyUser() && isVacancyOwner(request.resource.data)) || isSuperAdmin();
        allow delete: if (isPremiumCompanyUser() && isVacancyOwner(resource.data)) || isSuperAdmin();
    }


    /* =====================================================
     * Default Deny (implicit)
     * ===================================================== */
  }
}
