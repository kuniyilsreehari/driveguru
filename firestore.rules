
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
     * Helper Functions
     * ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }
    
    function isManager() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid));
    }
    
    function isExistingDoc() {
      return resource != null;
    }
    
    function isNewDoc() {
      return resource == null;
    }
    
    function requestData() {
      return request.resource.data;
    }
    
    function isCreatingOwnUserDoc(userId) {
      // Very permissive rule for debugging. 
      // In production, you'd want to validate fields.
      return isOwner(userId);
    }
    
    // A user can update certain fields of their own profile.
    function isUpdatingOwnUserDoc(userId) {
      // All fields a user is allowed to edit on their own.
      let editableFields = [
        'firstName', 'lastName', 'photoUrl', 'state', 'city', 'pincode', 'address', 'latitude', 'longitude', 'countryCode',
        'phoneNumber', 'showPhoneNumberOnProfile', 'department', 'companyName', 'businessDescription', 'category', 'profession',
        'pricingModel', 'pricingValue',
        'experienceYears', 'experienceMonths', 'gender', 'qualification', 'collegeName',
        'skills', 'aboutMe', 'aboutYourDream', 'associatedProjectsName',
        'linkedinUrl', 'twitterUrl', 'githubUrl', 'portfolioUrl', 'facebookUrl', 'instagramUrl', 'youtubeUrl',
        'isAvailable', 'following'
      ];
      let allAffectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      
      return isOwner(userId) && isExistingDoc() && allAffectedKeys.hasOnly(editableFields);
    }

    // A manager can only update verification and cash payment status.
    function isManagerUpdatingUserDoc() {
      let editableFields = ['verified', 'cashPaymentStatus'];
      let allAffectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return isManager() && isExistingDoc() && allAffectedKeys.hasOnly(editableFields);
    }

    function isCreatingOwnLocationData(userId) {
      return isCreatingOwnUserDoc(userId) && requestData().userId == userId;
    }

    function locationUserImmutable() {
      return requestData().userId == resource.data.userId;
    }

    function isMemberOfCompany(companyId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc.data.companyId == companyId;
    }
    
    function isCompanyUser() {
        return isSignedIn() && request.auth.uid != null;
    }

    function isPremiumCompanyUser() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() &&
             userDoc.data.role == 'Company' &&
             (userDoc.data.tier == 'Premier' || userDoc.data.tier == 'Super Premier');
    }

    function isVacancyOwner(vacancy) {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return isCompanyUser() && 'companyId' in userDoc.data && vacancy.companyId == userDoc.data.companyId;
    }
    
    function isCreatingCorrectVacancy() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        // The companyId in the new vacancy must match the companyId of the user creating it.
        // Also ensure the user document has a companyId to compare against.
        return 'companyId' in userDoc.data && requestData().companyId == userDoc.data.companyId;
    }

    function isPremiumExpert() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return isSignedIn() && 
               (userDoc.data.tier == 'Premier' || userDoc.data.tier == 'Super Premier');
    }

    function isTargetExpertPremium(expertId) {
      let expertDoc = get(/databases/$(database)/documents/users/$(expertId));
      return expertDoc.data.tier == 'Premier' || expertDoc.data.tier == 'Super Premier';
    }


    /* =====================================================
     * Admin Roles
     * ===================================================== */

    match /roles_super_admin/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list, create, update, delete: if isSuperAdmin();
    }
    
    match /roles_manager/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin() || isManager();
      allow list, create, update, delete: if isSuperAdmin();
    }


    /* =====================================================
     * App Configuration
     * ===================================================== */
    match /app_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    /* =====================================================
     * Companies
     * ===================================================== */

    match /companies/{companyId} {
      allow get: if isSignedIn(); // Any signed-in user can view company details.
      allow list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }
    
    /* =====================================================
     * Payments
     * ===================================================== */
    match /payments/{paymentId} {
        // Users can create their own payment record, but can't specify status or update it later.
        allow create: if isOwner(requestData().userId) && requestData().status == 'pending';
        // Users can read their own payment records. Admins can read any.
        allow get: if isOwner(resource.data.userId) || isSuperAdmin();
        // Admins can list all payments. Users can list their own.
        allow list: if isSuperAdmin() || (isSignedIn() && request.query.where.userId == request.auth.uid);
        // Only super admins can update payment status.
        allow update, delete: if isSuperAdmin();
    }


    /* =====================================================
     * Users
     * ===================================================== */

    match /users/{userId} {
      // Anyone can view any public profile.
      allow get, list: if true;

      // VERY PERMISSIVE: Any signed-in user can create their own user document.
      allow create: if isOwner(userId);

      // A user can update their own document, or an admin/manager can update specific fields.
      allow update: if isUpdatingOwnUserDoc(userId) || isManagerUpdatingUserDoc() ||
                       (isSuperAdmin() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'createdAt']));

      // Users can delete their own account, and admins can delete any account.
      allow delete: if isOwner(userId) || isSuperAdmin();

      /* ---------------------------------------------
       * Private Location Data (STRICT PRIVACY)
       * --------------------------------------------- */

      match /location_data/{locationDataId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnLocationData(userId);
        allow update: if isOwner(userId) && locationUserImmutable();
        allow delete: if isOwner(userId);
      }
    }
    
    /* =====================================================
     * Vacancies
     * ===================================================== */
    match /vacancies/{vacancyId} {
        // Anyone can read and list job vacancies.
        allow get, list: if true;
        // Only premium company users or super admins can create vacancies.
        allow create: if (isPremiumCompanyUser() && isCreatingCorrectVacancy()) || isSuperAdmin();
        // Only the company that owns the vacancy (and is premium) or a super admin can update it.
        allow update: if (isPremiumCompanyUser() && isVacancyOwner(requestData())) || isSuperAdmin();
        // Only the company that owns the vacancy (and is premium) or a super admin can delete it.
        allow delete: if (isPremiumCompanyUser() && isVacancyOwner(resource.data)) || isSuperAdmin();
    }


    /* =====================================================
     * Default Deny (implicit)
     * ===================================================== */
  }
}
