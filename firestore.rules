
/**
 * Core Philosophy: This ruleset implements a multi-tiered security model. It combines a strict
 * user-ownership model for private data (like location tracking) with a powerful, role-based
 * access control system for administrative functions. A special "Super Admin" role grants
 * broad permissions to manage core application entities like users and companies.
 *
 * Data Structure:
 * - /users/{userId}: Stores public user profiles.
 * - /users/{userId}/location_data/{locationDataId}: A private subcollection containing a user's
 *   sensitive location history. Access is strictly limited to the user who owns the data.
 * - /companies/{companyId}: A top-level collection for company data.
 * - /roles_super_admin/{userId}: An authorization-specific collection. The existence of a
 *   document here grants a user Super Admin privileges across the application.
 * - /reviews/{reviewId}: A collection for expert reviews, moderated by Super Admins.
 * - /categories/{categoryId}: Stores service categories, managed by Super Admins.
 *
 * Key Security Decisions:
 * - Super Admin Role: A user is a Super Admin if a document with their UID exists
 *   in the /roles_super_admin collection. This role grants read/write access to the /users,
 *   /companies, /reviews and /categories collections. This avoids costly lookups on user documents for role checks.
 * - User Privacy: Users can only read/update their own profile and create their own location
 *   data. They cannot list other users or access another user's private subcollections unless public.
 * - Location Data: This data is considered highly sensitive and is secured using a path-based
 *   ownership model. Only the user specified in the path can access their location data. Super
 *   Admins are explicitly denied access to maintain user privacy.
 * - Immutable Ownership: Relational fields critical for authorization, such as a user's own ID
 *   within their document, are enforced as immutable to prevent ownership hijacking.
 * - Default Deny: All paths not explicitly matched are denied access by default.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the requesting user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the requesting user is a Super Admin by checking for the
     * existence of their UID in the roles_super_admin collection.
     * This is a performant way to manage global roles.
     */
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }

    /**
     * Validates that a new user document is being created correctly.
     * Enforces that the document ID matches the user's UID, the 'id' field matches,
     * and key fields like 'verified' and 'isAvailable' are set to their proper initial values.
     */
    function isCreatingOwnUserDoc(userId) {
      let resourceData = request.resource.data;
      return isOwner(userId) && 
             resourceData.id == userId &&
             resourceData.verified == false &&
             resourceData.isAvailable == true;
    }

    /**
     * Validates that critical, immutable fields of a user document are not changed on update.
     * A regular user cannot change their ID or their verification status.
     * A Super Admin can change any field except the user ID.
     */
    function userFieldsAreValidOnUpdate() {
        let isIdImmutable = request.resource.data.id == resource.data.id;
        
        // A non-admin user cannot change their 'verified' status.
        if (!isSuperAdmin()) {
            // The 'verified' field must not change from its existing value.
             let isVerifiedUnchanged = !('verified' in request.resource.data) || request.resource.data.verified == resource.data.verified;
            return isIdImmutable && isVerifiedUnchanged;
        }
        
        return isIdImmutable;
    }
    
    /**
     * Validates that the userId in new location data matches the parent document's user ID.
     */
    function isCreatingOwnLocationData(userId) {
      return request.resource.data.userId == userId;
    }
    
    /**
     * Validates that the userId in location data is immutable on update.
     */
    function locationDataFieldsAreImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    /**
     * Validates that a new review is being created by the authenticated user
     * and that its initial status is 'pending'. This prevents users from creating
     * reviews for others or bypassing the moderation queue.
     */
    function isCreatingOwnReview() {
      return isSignedIn() && 
             request.resource.data.reviewerId == request.auth.uid &&
             request.resource.data.status == 'pending';
    }

    // --------------------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Controls access to Super Admin role assignments. Only existing Super
     * Admins can manage administrative privileges. A user can check their own role.
     */
    match /roles_super_admin/{userId} {
      allow get: if isOwner(userId);
      allow list, create, update, delete: if isSuperAdmin();
    }
    
    /**
     * @description Controls access to reviews. Anyone can read approved reviews.
     * Authenticated users can create their own reviews (which start as 'pending').
     * Super Admins can moderate (update status/delete) all reviews.
     */
    match /reviews/{reviewId} {
      allow list, get: if true;
      allow create: if isCreatingOwnReview();
      allow update, delete: if isSuperAdmin();
    }

    /**
     * @description Defines access rules for company profiles. Only Super Admins have
     * full read and write control.
     */
     match /companies/{companyId} {
      allow get, list, create, update, delete: if isSuperAdmin();
    }
    
    /**
     * @description Defines access rules for categories. Super Admins have
     * full read and write control. All users can read categories.
     */
     match /categories/{categoryId} {
        allow read: if true;
        allow write: if isSuperAdmin();
     }

    /**
     * @description Manages access to user profile documents. Anyone can read profiles.
     * Users can create and securely update their own profile. Super Admins have broad
     * management capabilities.
     */
    match /users/{userId} {
      allow get: if true;
      allow list: if isSuperAdmin();
      allow create: if isCreatingOwnUserDoc(userId);
      allow update: if (isOwner(userId) && userFieldsAreValidOnUpdate()) || isSuperAdmin();
      allow delete: if isOwner(userId) || isSuperAdmin();

      /**
       * @description Secures a user's private location data. Access is strictly limited to
       * the owner. Even Super Admins cannot access this sensitive information to protect user privacy.
       */
      match /location_data/{locationDataId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
