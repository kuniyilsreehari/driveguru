
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
     * Helper Functions
     * ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }
    
    function isManager() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid));
    }

    /* =====================================================
     * Global Read Access (Marketplace Visibility)
     * ===================================================== */
    match /users/{userId} { allow read, list: if true; }
    match /posts/{postId} { allow read, list: if true; }
    match /groups/{groupId} { allow read, list: if true; }
    match /vacancies/{vacancyId} { allow read, list: if true; }
    match /app_config/{configId} { allow read, list: if true; }
    match /roles_super_admin/{userId} { allow read: if isSignedIn(); }
    match /roles_manager/{userId} { allow read: if isSignedIn(); }

    /* =====================================================
     * Specialized Write Access
     * ===================================================== */

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow update: if isSuperAdmin() || isOwner(userId);
      allow delete: if isSuperAdmin() || isOwner(userId);

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isSignedIn();
      }
      
      match /location_data/{locId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    match /posts/{postId} {
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (isSignedIn() && (resource.data.authorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])));
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update: if isSuperAdmin() || (isSignedIn() && (resource.data.authorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])));
        allow delete: if isSuperAdmin() || (isSignedIn() && (resource.data.authorId == request.authorId || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid));
      }
    }
    
    match /groups/{groupId} {
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (isSignedIn() && (resource.data.creatorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasAny(['members', 'pendingMembers'])));
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.creatorId == request.auth.uid);
      
      match /posts/{postId} {
        allow read, list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }
    
    match /vacancies/{vacancyId} {
      allow create, update, delete: if isSuperAdmin();
    }
    
    match /payments/{paymentId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isSuperAdmin();
    }

    match /roles_super_admin/{userId} { allow write: if isSuperAdmin(); }
    match /roles_manager/{userId} { allow write: if isSuperAdmin(); }
    match /app_config/{configId} { allow write: if isSuperAdmin(); }
  }
}
