
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
     * Helper Functions
     * ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }
    
    function requestData() {
      return request.resource.data;
    }
    
    // A user can update certain fields of their own profile.
    function isUpdatingOwnUserDoc(userId) {
      let protectedFields = ['id', 'email', 'verified', 'role', 'tier', 'createdAt', 'referralCode', 'referralPoints', 'referredByCode'];
      return isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedFields);
    }
    
    function isPremiumExpert() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return isSignedIn() && 
               (userDoc.data.tier == 'Premier' || userDoc.data.tier == 'Super Premier');
    }
    
    function isPremiumCompanyUser() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() &&
             userDoc.data.role == 'Company' &&
             (userDoc.data.tier == 'Premier' || userDoc.data.tier == 'Super Premier');
    }
    
    function isVacancyOwner(vacancy) {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return isCompanyUser() && vacancy.companyId == userDoc.data.companyId;
    }
    
    function isCompanyUser() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return isSignedIn() && userDoc.data.role == 'Company';
    }


    /* =====================================================
     * Admin & Config (Required for app to function)
     * ===================================================== */

    match /roles_super_admin/{userId} {
      allow read, write: if isSuperAdmin();
    }

    match /app_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    /* =====================================================
     * User Profiles
     * ===================================================== */
    match /users/{userId} {
      // Anyone can view a public profile.
      allow get: if true;
      // Only signed-in users can search/list profiles.
      allow list: if isSignedIn();
      // Users can create their own profile, and admins can create profiles.
      allow create: if isOwner(userId) || isSuperAdmin();
      // Users can update their own profile (with field restrictions), and admins can update any profile.
      allow update: if isUpdatingOwnUserDoc(userId) || isSuperAdmin();
      // Admins can delete users.
      allow delete: if isSuperAdmin();
    }

    /* =====================================================
     * Bookings (Premium Feature)
     * ===================================================== */
    match /bookings/{bookingId} {
        // A client can create a booking for an expert. A premium expert can log their own booking.
        allow create: if isSignedIn() && (requestData().clientId == request.auth.uid || (isPremiumExpert() && requestData().expertId == request.auth.uid));
        // The expert or the client who made the booking can view it.
        allow get: if (isPremiumExpert() && resource.data.expertId == request.auth.uid) || (isSignedIn() && resource.data.clientId == request.auth.uid);
        // An expert can manage their own bookings (update status, delete).
        allow update, delete: if isPremiumExpert() && resource.data.expertId == request.auth.uid;
        // An expert can list their own bookings.
        allow list: if isPremiumExpert() && request.query.where.expertId == request.auth.uid;
    }

    /* =====================================================
     * Reviews
     * ===================================================== */
    match /reviews/{reviewId} {
        // Anyone can read approved reviews. Admins can read all.
        allow get: if resource.data.status == 'approved' || isSuperAdmin();
        // Allow listing only approved reviews for public, all for admin.
        allow list: if request.query.where.status == 'approved' || isSuperAdmin();
        // Any signed-in user can create a review (it will be 'pending'). Admins can create any status.
        allow create: if (isSignedIn() && requestData().status == 'pending') || isSuperAdmin();
        // Only admins can update or delete reviews.
        allow update, delete: if isSuperAdmin();
    }
    
    /* =====================================================
     * Vacancies (Premium Company Feature)
     * ===================================================== */
    match /vacancies/{vacancyId} {
        // Anyone can read and list job vacancies.
        allow get, list: if true;
        // Only premium company users or super admins can create/update/delete vacancies.
        allow create, update, delete: if isPremiumCompanyUser() || isSuperAdmin();
    }
    
    /* =====================================================
     * Payments
     * ===================================================== */
    match /payments/{paymentId} {
        // Users can create their own pending payment records.
        allow create: if isOwner(requestData().userId) && requestData().status == 'pending';
        // Users can view their own payments. Admins can view any.
        allow get: if isOwner(resource.data.userId) || isSuperAdmin();
        // Users can list their own payments. Admins can list all.
        allow list: if (isSignedIn() && request.query.where.userId == request.auth.uid) || isSuperAdmin();
        // Only admins can update payment status.
        allow update, delete: if isSuperAdmin();
    }
  }
}
