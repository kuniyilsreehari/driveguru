rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // GLOBAL READ ACCESS: Required for marketplace listing and searching.
    match /{path=**} {
      allow read: if true;
    }

    /* =====================================================
     * Helper Functions
     * ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid));
    }
    
    function isExistingDoc() {
      return resource != null;
    }
    
    function requestData() {
      return request.resource.data;
    }

    /* =====================================================
     * Collections
     * ===================================================== */

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow update: if isSuperAdmin() || isOwner(userId);
      allow delete: if isSuperAdmin() || isOwner(userId);

      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
      
      match /location_data/{locId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    match /posts/{postId} {
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      
      match /comments/{commentId} {
        allow create: if isSignedIn();
        allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }
    
    match /groups/{groupId} {
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.creatorId == request.auth.uid);
      
      match /posts/{postId} {
        allow create: if isSignedIn();
        allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }
    
    match /vacancies/{vacancyId} {
      allow create: if isSuperAdmin() || (isSignedIn());
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.companyId == request.auth.uid);
    }
    
    match /payments/{paymentId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isSuperAdmin();
    }

    match /roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    match /roles_manager/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    match /app_config/{configId} {
      allow write: if isSuperAdmin();
    }
  }
}