rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
     * Helper Functions
     * ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.role == "superAdmin" ||
        request.auth.uid == "UtMmElKnuMXbOM2cBP4oM6bFTre2" ||
        request.auth.token.email == "kuniyilsreehari@gmail.com" ||
        request.auth.token.email == "royatosolutions@gmail.com" ||
        exists(/databases/$(database)/documents/roles_super_admin/$(request.auth.uid))
      );
    }
    
    function isManager() {
      return isSignedIn() && (
        request.auth.token.role == "manager" ||
        exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid)) ||
        isSuperAdmin()
      );
    }

    /* =====================================================
     * Collection Rules
     * ===================================================== */

    // User Profiles - Publicly readable for search and discovery
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId);
      allow update: if isSuperAdmin() || isOwner(userId);
      allow delete: if isSuperAdmin();

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isSignedIn();
      }
      
      match /location_data/{locId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Global App Configuration - Publicly readable
    match /app_config/{configId} { 
      allow read, list: if true;
      allow write: if isSuperAdmin(); 
    }

    // Job Vacancies - Publicly readable
    match /vacancies/{vacancyId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.companyId == request.auth.uid);
    }
    
    // Public Feed Posts - Publicly readable
    match /posts/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (isSignedIn() && (resource.data.authorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])));
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update: if isSuperAdmin() || (isSignedIn() && (resource.data.authorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])));
        allow delete: if isSuperAdmin() || (isSignedIn() && (resource.data.authorId == request.authorId || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid));
      }
    }
    
    // Professional Groups
    match /groups/{groupId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (isSignedIn() && (resource.data.creatorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasAny(['members', 'pendingMembers'])));
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.creatorId == request.auth.uid);
      
      match /posts/{postId} {
        allow read, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members || isSuperAdmin());
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }
    
    // Payments and Subscriptions
    match /payments/{paymentId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isSuperAdmin();
    }

    // Role Management Collections
    match /roles_super_admin/{userId} { 
      allow read: if isSignedIn();
      allow write: if isSuperAdmin(); 
    }
    
    match /roles_manager/{userId} { 
      allow read: if isSignedIn();
      allow write: if isSuperAdmin(); 
    }
  }
}